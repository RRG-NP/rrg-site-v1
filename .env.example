# SMTP Configuration for Contact Form
# Copy this file to .env.local and fill in your actual values

# Your SMTP email address (e.g., your-email@gmail.com)
EMAIL_USER=your-email@example.com

# Your SMTP password or app-specific password
# For Gmail: Generate an app password at https://myaccount.google.com/apppasswords
EMAIL_PASS=your-app-password

# Recipient email address (where form submissions should be sent)
# If not set, defaults to EMAIL_USER
EMAIL_TO=recipient@example.com

# SMTP server hostname
# Gmail: smtp.gmail.com
# Outlook: smtp-mail.outlook.com
# Yahoo: smtp.mail.yahoo.com
SMTP_HOST=smtp.gmail.com

# SMTP server port
# TLS: 587 (recommended)
# SSL: 465
SMTP_PORT=587

# Use SSL connection
# 'true' for port 465 (SSL)
# 'false' for port 587 (TLS)
SMTP_SECURE=false
